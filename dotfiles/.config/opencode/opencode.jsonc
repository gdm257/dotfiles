      "home-manager build *": "allow",
      "home-manager generations *": "allow",
      "xmake *": "allow",
      "cmake *": "allow",
      "make *": "allow",
      "task *": "allow",
      "just *": "allow",
      "mise run *": "allow",
      "uv *": "allow",
      "poetry *": "allow",
      "rye *": "allow",
      "pdm *": "allow",
      "pnpm *": "allow",
      "bun *": "allow",
      "deno *": "allow",
      "yarn *": "allow",
      "npm *": "allow",
      "go *": "allow",
      "cargo *": "allow"
    }
  }
}
