      "go test *": "allow",
      "go build *": "allow",
      "rustc *": "allow",
      "cargo build *": "allow",
      "tsc *": "allow",
      "vite *": "allow",
      "esbuild *": "allow",
      "python -m py_compile *": "allow",
      "py_compile *": "allow",
      "nix *": "allow",
      "nix-collect-garbage *": "allow",
      "nix-store *": "allow",
      "nix-why-depends *": "allow",
      "nix-build *": "allow",
      "nix-env *": "allow",
      "nixos-rebuild build *": "allow",
