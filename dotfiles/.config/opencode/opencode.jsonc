      "q *": "allow",
      "pandoc *": "allow",
      "mkcert *": "allow",
      "step *": "allow",
      "oauth2l *": "allow",
      "oauth2c *": "allow",
      "clip *": "allow",
      "xclip *": "allow",
      "tar *": "allow",
      "zip *": "allow",
      "7z *": "allow",
      "unzip *": "allow",
      "rmdir *": "allow",
