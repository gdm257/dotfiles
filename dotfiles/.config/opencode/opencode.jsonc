{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "formatter": {
    "oxfmt": {
      "disabled": true
    },
    "oxfmt-custom": {
      "command": [
        "bunx",
        "oxfmt",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".mjs",
        ".cjs",
        ".ts",
        ".mts",
        ".cts",
        ".jsx",
        ".tsx",
        ".mdx",
        ".md",
        ".html",
        ".vue",
        ".hbs",
        ".css",
        ".scss",
        ".less",
        ".json",
        ".jsonc",
        ".json5",
        ".yaml",
        ".yml",
        ".toml",
        ".graphql",
        ".gql"
      ]
    }
  },
  "small_model": "deepseek/deepseek-v4-flash",
  "disabled_providers": [
    "anthropic",
    "openai",
    "opencode"
  ],
  "provider": {
    "ark": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ark",
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/coding/v3"
      },
      "models": {
        "ark-code-latest": {
          "name": "auto",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "glm-4.7": {
          "name": "glm-4.7"
        },
        "glm-5.1": {
          "name": "glm-5.1"
        },
        "minimax-latest": {
          "name": "minimax"
        },
        "kimi-k2.6": {
          "name": "kimi-k2.6"
        }
      }
    },
    "cherry-studio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cherry Studio",
      "options": {
        "baseURL": "http://localhost:23333/v1"
      },
      "models": {}
    },
    "kuaipao": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "KuaiPao API",
      "options": {
        "baseURL": "https://kuaipao.pro/v1"
      },
      "models": {
        "gpt-5.6-luna": {
          "name": "gpt-5.6-luna",
          "options": {}
        }
      }
    }
  },
  "instructions": [
    ".claude/rules/**.md"
  ],
  "plugin": [
    "opencode-wakatime@1.3.8",
    "@dietrichgebert/ponytail"
  ],
  "compaction": {
    "prune": true,
    "auto": true,
    "reserved": 80000
  },
  "agent": {},
  "command": {},
  "mcp": {
    "codebase-memory": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ],
      "enabled": true
    },
    "semble": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "semble[mcp]",
        "semble"
      ],
      "enabled": true
    }
  },
  "shell": "bash",
  "permission": {
    "agent": {
      "Explore": "deny"
    },
    "bash": {
      "git push *": "ask",
      "git push": "ask",
      "jj git push *": "ask",
      "jj git push": "ask",
      "xmake push *": "ask",
      "xmake push": "ask",
      "xmake publish *": "ask",
      "xmake publish": "ask",
      "xmake release *": "ask",
      "xmake release": "ask",
