      "git submodule deinit *": "allow",
      "git fetch *": "allow",
      "jj help *": "allow",
      "jj version *": "allow",
      "jj status *": "allow",
      "jj diff *": "allow",
      "jj interdiff *": "allow",
      "jj log *": "allow",
      "jj evolog *": "allow",
      "jj show *": "allow",
      "jj gerrit *": "allow",
      "jj sign *": "allow",
      "jj new *": "allow",
      "jj commit *": "allow",
      "jj split *": "allow",
      "jj root *": "allow",
