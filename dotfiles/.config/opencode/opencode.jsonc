      "gh release verify-asset *": "allow",
      "gh release view *": "allow",
      "gh repo list *": "allow",
      "gh repo clone *": "allow",
      "gh repo gitignore *": "allow",
      "gh repo license *": "allow",
      "gh repo set-default *": "allow",
      "gh repo view *": "allow",
      "gh cache *": "allow",
      "gh run list *": "allow",
      "gh run cancel *": "allow",
      "gh run download *": "allow",
      "gh run rerun *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "gh workflow list *": "allow",
      "gh workflow view *": "allow",
      "gh accessibility *": "allow",
      "gh actions *": "allow",
      "gh environment *": "allow",
      "gh exit-codes *": "allow",
      "gh formatting *": "allow",
      "gh mintty *": "allow",
      "gh reference *": "allow",
      "gh extension *": "allow",
      "gh config *": "allow",
      "gh ruleset *": "allow",
      "gh search *": "allow",
      "gh status *": "allow",
      "cc-sdd *": "allow",
      "bunx cc-sdd *": "allow",
      "npx cc-sdd *": "allow",
      "openspec *": "allow",
      "bunx @fission-ai/openspec *": "allow",
      "npx @fission-ai/openspec *": "allow",
      "openskills *": "allow",
      "bunx openskills *": "allow",
      "npx openskills *": "allow",
      "systemctl status *": "allow",
      "docker stack config *": "allow",
      "docker compose config *": "allow",
      "docker-compose config *": "allow",
      "gf *": "allow",
      "ent *": "allow",
      "go generate *": "allow",
      "go fmt *": "allow",
      "gofmt *": "allow",
      "ruff *": "allow",
      "biome *": "allow",
