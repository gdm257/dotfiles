{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "formatter": {
    "oxfmt": {
      "disabled": true
    },
    "oxfmt-custom": {
      "command": [
        "bunx",
        "oxfmt",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".mjs",
        ".cjs",
        ".ts",
        ".mts",
        ".cts",
        ".jsx",
        ".tsx",
        ".mdx",
        ".md",
        ".html",
        ".vue",
        ".hbs",
        ".css",
        ".scss",
        ".less",
        ".json",
        ".jsonc",
        ".json5",
        ".yaml",
        ".yml",
        ".toml",
        ".graphql",
        ".gql"
      ]
    }
  },
  "small_model": "deepseek/deepseek-v4-flash",
  "disabled_providers": [
    "anthropic",
    "openai",
    "opencode"
  ],
  "provider": {
    "ark": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ark",
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/coding/v3"
      },
      "models": {
        "ark-code-latest": {
          "name": "auto",
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "glm-4.7": {
          "name": "glm-4.7"
        },
        "glm-5.1": {
          "name": "glm-5.1"
        },
        "minimax-latest": {
          "name": "minimax"
        },
        "kimi-k2.6": {
          "name": "kimi-k2.6"
        }
      }
    },
    "cherry-studio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cherry Studio",
      "options": {
        "baseURL": "http://localhost:23333/v1"
      },
      "models": {}
    }
  },
  "instructions": [
    ".claude/rules/**.md"
  ],
  "plugin": [
    "opencode-wakatime@1.3.8",
    "@dietrichgebert/ponytail"
  ],
  "compaction": {
    "prune": true,
    "auto": true,
    "reserved": 80000
  },
  "agent": {},
  "command": {},
  "mcp": {
    "code-review-graph": {
      "type": "local",
      "command": [
        "uvx",
        "code-review-graph",
        "serve"
      ],
      "enabled": true
    },
    "semble": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "semble[mcp]",
        "semble"
      ],
      "enabled": true
    }
  },
  "shell": "bash",
  "permission": {
    "agent": {
      "Explore": "deny"
    },
    "bash": {
      "git push *": "ask",
      "jj git push *": "ask",
      "xmake push *": "ask",
      "xmake publish *": "ask",
      "xmake release *": "ask",
      "make push *": "ask",
      "make publish *": "ask",
      "make release *": "ask",
      "task push *": "ask",
      "task publish *": "ask",
      "task release *": "ask",
      "just push *": "ask",
      "just publish *": "ask",
      "just release *": "ask",
      "uv push *": "ask",
      "uv publish *": "ask",
      "uv release *": "ask",
      "poetry push *": "ask",
      "poetry publish *": "ask",
      "poetry release *": "ask",
      "pdm push *": "ask",
      "pdm publish *": "ask",
      "pdm release *": "ask",
      "npm publish *": "ask",
      "pnpm publish *": "ask",
      "bun publish *": "ask",
      "yarn publish *": "ask",
      "cargo publish *": "ask",
      "go doc *": "allow",
      "pydoc *": "allow",
      "cargo doc *": "allow",
      "tldx *": "allow",
      "tldr *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "http *": "allow",
      "https *": "allow",
      "curlie *": "allow",
      "hurl *": "allow",
      "xh *": "allow",
      "grpcurl *": "allow",
      "ipconfig *": "allow",
      "ifconfig *": "allow",
      "ping *": "allow",
      "dig *": "allow",
      "dog *": "allow",
      "doggo *": "allow",
      "nmap *": "allow",
      "naabu *": "allow",
      "tlsx *": "allow",
      "whosip *": "allow",
      "whois *": "allow",
      "hostctl *": "allow",
      "date *": "allow",
