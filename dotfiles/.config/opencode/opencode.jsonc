      "gh gist view *": "allow",
      "gh issue list *": "allow",
      "gh issue status *": "allow",
      "gh issue view *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "gh pr diff *": "allow",
